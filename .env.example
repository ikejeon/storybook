# Moon Jar Stories offline asset pipeline settings.
# Copy to .env locally if desired. Never commit real keys.

MOONJAR_ASSET_MODE=placeholder

# Image generation / upscaling / layer extraction.
# Generation runs offline/dev-time only. The child app must never call these.
MOONJAR_IMAGE_PROVIDER=openai_image
OPENAI_API_KEY=
MOONJAR_OPENAI_IMAGE_MODEL=gpt-image-1
MOONJAR_OPENAI_RESPONSES_MODEL=gpt-5
MOONJAR_OPENAI_IMAGE_SIZE=1536x1024
MOONJAR_OPENAI_IMAGE_QUALITY=high
ADOBE_FIREFLY_API_KEY=
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_MODEL=firefly-image
MOONJAR_IMAGE_API_KEY=
MOONJAR_IMAGE_MODEL=
MOONJAR_UPSCALE_API_KEY=
MOONJAR_UPSCALE_MODEL=
MOONJAR_LAYER_API_KEY=
MOONJAR_LAYER_MODEL=

# Korean / English TTS
MOONJAR_AUDIO_PROVIDER=macos_say
# Recommended production providers to wire through tools/providers/external_api.py:
# - OpenAI speech API, e.g. gpt-4o-mini-tts, for directed storyteller delivery.
# - ElevenLabs TTS, for audiobook-style voices with stability/similarity/style controls.
# - Resemble AI, for custom/professional cloned voices and WAV output workflows.
MOONJAR_KO_TTS_API_KEY=
MOONJAR_KO_TTS_MODEL=
MOONJAR_EN_TTS_API_KEY=
MOONJAR_EN_TTS_MODEL=
MOONJAR_OPENAI_TTS_MODEL=gpt-4o-mini-tts
MOONJAR_OPENAI_TTS_VOICE=coral
MOONJAR_ELEVENLABS_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_EN_VOICE_ID=
ELEVENLABS_KO_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
NAVER_CLOVA_CLIENT_ID=
NAVER_CLOVA_CLIENT_SECRET=
NAVER_CLOVA_VOICE=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_TTS_VOICE=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=
MOONJAR_RESEMBLE_API_TOKEN=
MOONJAR_RESEMBLE_VOICE_UUID=
MOONJAR_MACOS_KO_VOICE=Grandma (Korean (South Korea))
MOONJAR_MACOS_EN_VOICE=Grandma (English (US))
MOONJAR_TTS_RATE=140
MOONJAR_AUDIO_TARGET_PEAK_DB=-3.0

# Audio mastering and sound effects
MOONJAR_AUDIO_MASTERING_API_KEY=
MOONJAR_AUDIO_MASTERING_MODEL=
MOONJAR_SFX_API_KEY=
MOONJAR_SFX_MODEL=

# Manual imports
MOONJAR_COMMISSIONED_IMPORT_ROOT=
MOONJAR_SUN_MOON_SCENE_IMPORT_ROOT=shared-content/assets/manual-import/images/sun-and-moon
